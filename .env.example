# App
APP_ENV=development          # development | production (production → gin ReleaseMode)
LOG_LEVEL=info               # debug | info | warn | error
LOG_FORMAT=json              # json (prod) | text (dev อ่านง่าย)

# HTTP
HTTP_PORT=8080
HTTP_READ_TIMEOUT=5s
HTTP_WRITE_TIMEOUT=10s
HTTP_SHUTDOWN_TIMEOUT=10s

# SQL Server
DB_HOST=192.168.251.120
DB_PORT=1433
DB_USER=apidej
DB_PASSWORD=********
DB_NAME=easymoney_dev
DB_ENCRYPT=disable           # dev มักใช้ disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=25
DB_CONN_MAX_LIFETIME=5m

# External API (pawnshop) — base host; path ของ virtualsoap ต่อในโค้ด
PAWN_URL=https://pawnshop-api-dev-xxxx.azurewebsites.net/   # base host ของ internal API
TICKET_API_KEY=                                            # Authorization: Bearer <key> (ว่าง = ไม่ส่ง)
TICKET_API_TIMEOUT=10s                                     # timeout ต่อ request external
